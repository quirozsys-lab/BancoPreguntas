@page "/"
@namespace BancoPreguntas.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using MudBlazor  @* <─── AGREGA ESTA LÍNEA AQUÍ *@
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Banco de Preguntas MINEDU</title>
    <base href="~/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="css/app.css" rel="stylesheet" />
</head>
<body>

    <component type="typeof(MudThemeProvider)" render-mode="ServerPrerendered" />
    <component type="typeof(MudDialogProvider)" render-mode="ServerPrerendered" />
    <component type="typeof(MudSnackbarProvider)" render-mode="ServerPrerendered" />
    <component type="typeof(MudPopoverProvider)" render-mode="ServerPrerendered" />

    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <script src="_framework/blazor.server.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        window.clickElement = function(id) {
        document.getElementById(id).click();
        }
    </script>
</body>
</html>